# Azure OpenAI — credenziali principali
AZURE_OPENAI_ENDPOINT=https://<nome-risorsa>.openai.azure.com/
AZURE_OPENAI_API_KEY=<api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version per Chat Completions (Vanilla + Agente Bilancio)
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# API version per Responses API (RAG + Agente Preventivi) — richiede preview
AZURE_OPENAI_API_VERSION_RESPONSES=2025-04-01-preview

# Vector store per la modalità RAG (Assistente RAG)
# Crea con: python scripts/setup_vector_store.py
AZURE_VECTOR_STORE_ID=

# Vector store per l'Agente Preventivi (knowledge base materiali/processi)
# Crea con: python scripts/setup_preventivi_kb.py
AZURE_PREVENTIVI_VECTOR_STORE_ID=

# Auth — password condivisa con gli studenti (lascia vuoto per disattivare l'auth in dev)
ACCESS_TOKEN=

# Limiti (valori di default già nel codice, override opzionale)
MAX_OUTPUT_TOKENS=800
MAX_HISTORY_MESSAGES=30
RATE_LIMIT=30/minute
