# ============================================================
# Vanilla LLM Demo - Template variabili d'ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# Azure OpenAI - obbligatori
AZURE_OPENAI_ENDPOINT=https://<nome-risorsa>.openai.azure.com/
AZURE_OPENAI_API_KEY=<la-tua-api-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Nome del *deployment* su Azure (NON il nome del modello base).
# Suggerimento didattico: usa un modello "non-reasoning" come gpt-4o-mini
# o gpt-35-turbo, che mostra meglio i comportamenti vanilla (allucinazioni,
# errori sui conteggi, ecc.).
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Password condivisa per accedere alla webapp.
# Lasciala vuota in dev locale per disattivare l'auth.
ACCESS_TOKEN=cambia-questa-stringa-in-produzione

# Limiti operativi (opzionali, hanno default ragionevoli)
MAX_OUTPUT_TOKENS=800
MAX_HISTORY_MESSAGES=30
RATE_LIMIT=30/minute
